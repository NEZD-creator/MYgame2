service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for User Sync Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        isValidId(userId) &&
        request.resource.data.gold is number &&
        request.resource.data.updatedAt == request.time;
      allow delete: if false; // Progress cannot be deleted easily
    }

    // Rules for Leaderboard
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['username', 'stage', 'subStage', 'dps', 'glory', 'lastUpdated']) &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 64 &&
             data.stage is number &&
             data.subStage is number &&
             data.dps is number &&
             data.glory is number &&
             data.lastUpdated == request.time;
    }

    match /leaderboard/{uid} {
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == uid || (request.resource.data.keys().hasAll(['tgId']) && uid == request.resource.data.tgId)) && 
        isValidId(uid) && 
        isValidLeaderboardEntry(request.resource.data);
      allow delete: if false;
    }
  }
}
