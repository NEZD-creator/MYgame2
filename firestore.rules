service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'nevmovenko2004@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- COLLECTION RULES ---

    // 1. User Sync (Profile & Progress)
    function isValidUserSync(data) {
      return data.keys().hasAll(['gold', 'souls', 'crystals', 'glory', 'totalKills', 'updatedAt']) &&
             data.gold is number && 
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn(); // Allow searching for friends/clan members
      allow list: if isAdmin() || (isSignedIn() && resource.data.username != null); // Admin can list all, others only public
      allow create, update: if (isOwner(userId) || isAdmin()) && isValidUserSync(incoming());
      allow delete: if isAdmin();
      
      // Friends subcollection
      match /friends/{friendId} {
        allow read: if isOwner(userId) || isOwner(friendId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidId(friendId) && incoming().addedAt == request.time;
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // 2. Leaderboard
    match /leaderboard/{uid} {
      allow read: if true;
      allow create, update: if (isOwner(uid) || isAdmin()) && 
        incoming().keys().hasAll(['username', 'stage', 'lastUpdated']) &&
        incoming().lastUpdated == request.time;
      allow delete: if isAdmin();
    }

    // 3. Unique Nicknames (Unique Index)
    match /nicknames/{nickname} {
      allow read: if true;
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/nicknames/$(nickname)) && 
                     incoming().uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 4. Clans
    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && 
                     incoming().createdAt == request.time;
      allow update: if isAdmin() || (isOwner(existing().ownerId) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['description', 'members', 'totalGlory']));
      allow delete: if isAdmin();
    }

    // 5. Co-op Dungeons
    match /dungeons/{dungeonId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.hostId || request.auth.uid == resource.data.guestId || isAdmin());
      allow create: if isSignedIn() && incoming().hostId == request.auth.uid && 
                     incoming().status == 'waiting';
      allow update: if isSignedIn() && (
        // Joining as guest
        (existing().status == 'waiting' && incoming().guestId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['guestId', 'status', 'updatedAt'])) ||
        // Syncing positions & combat
        ((request.auth.uid == existing().hostId || request.auth.uid == existing().guestId) && 
         incoming().updatedAt == request.time)
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.hostId);
    }

    // 6. Social Invitations
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId || isAdmin());
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid && 
                     incoming().status == 'pending';
      allow update: if isSignedIn() && (
        (request.auth.uid == existing().toId && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId));
    }
  }
}
