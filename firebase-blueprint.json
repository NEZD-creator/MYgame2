{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A single entry in the global leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique ID of the player" },
        "username": { "type": "string", "description": "Display name of the player" },
        "stage": { "type": "number", "description": "Current stage level" },
        "subStage": { "type": "number", "description": "Current sub-stage" },
        "dps": { "type": "number", "description": "Total DPS" },
        "glory": { "type": "number", "description": "Total Glory" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Timestamp of the last update" }
      },
      "required": ["uid", "username", "stage", "subStage", "dps", "glory", "lastUpdated"]
    },
    "UserSync": {
      "title": "User Sync Data",
      "description": "Stored game state and profile for a user",
      "type": "object",
      "properties": {
        "gold": { "type": "number" },
        "souls": { "type": "number" },
        "crystals": { "type": "number" },
        "glory": { "type": "number" },
        "totalKills": { "type": "number" },
        "username": { "type": "string" },
        "clanId": { "type": "string" },
        "avatar": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Clan": {
      "title": "Clan",
      "description": "A player clan sharing progress",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array" },
        "totalGlory": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DungeonSession": {
      "title": "Dungeon Session",
      "description": "Active real-time co-op dungeon",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "active", "completed"] },
        "hostId": { "type": "string" },
        "guestId": { "type": "string" },
        "bossHealth": { "type": "number" },
        "hostX": { "type": "number" },
        "hostY": { "type": "number" },
        "guestX": { "type": "number" },
        "guestY": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/leaderboard/{uid}": {
      "schema": "LeaderboardEntry",
      "description": "Global leaderboard collection"
    },
    "/users/{userId}": {
      "schema": "UserSync",
      "description": "User specific game progress and profile"
    },
    "/nicknames/{nickname}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Index for unique nicknames"
    },
    "/clans/{clanId}": {
      "schema": "Clan",
      "description": "Clan collection"
    },
    "/dungeons/{dungeonId}": {
      "schema": "DungeonSession",
      "description": "Active co-op sessions"
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": { "type": "object", "properties": { "addedAt": { "type": "string", "format": "date-time" } } },
      "description": "User friends list"
    },
    "/invites/{inviteId}": {
      "schema": { "type": "object", "properties": { "fromId": { "type": "string" }, "toId": { "type": "string" }, "type": { "type": "string" }, "status": { "type": "string" } } },
      "description": "Social invitations (Clans, Friends, Dungeons)"
    }
  }
}
